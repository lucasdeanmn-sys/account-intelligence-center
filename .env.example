# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# HubSpot - Private App Token (from HubSpot Settings > Integrations > Private Apps)
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# Google OAuth Token (for Gmail + Calendar MCP servers)
# Get this by going through Google OAuth flow with scopes: gmail.readonly, calendar.readonly
GOOGLE_OAUTH_TOKEN=your_google_oauth_bearer_token_here

# CSSA (Computed Success Analysis) API Key
CSSA_API_KEY=your_cssa_api_key_here
